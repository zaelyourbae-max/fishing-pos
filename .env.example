# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/fishing_pos"

# =============================================================================
# SESSION
# =============================================================================

# Secret key untuk sign session token — wajib ≥ 32 karakter di production
# Generate: openssl rand -hex 32
SESSION_SECRET=""

# =============================================================================
# CRON
# =============================================================================

# Secret untuk mengamankan endpoint /api/cron/expire-pending dari akses publik
# Wajib di-set jika domain bisa diakses internet
# Generate: openssl rand -hex 32
CRON_SECRET=""

# =============================================================================
# APP URL
# =============================================================================

# URL publik aplikasi — dipakai untuk generate link invoice di WhatsApp
# Contoh: https://pos.namadomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Fallback jika NEXT_PUBLIC_APP_URL tidak tersedia di server-side
APP_URL="http://localhost:3000"

# =============================================================================
# ZONA WAKTU (TIMEZONE)
# =============================================================================

# Aplikasi sudah otomatis dikunci ke Asia/Makassar (WITA / Balikpapan, UTC+8)
# lewat instrumentation.ts saat server mulai — jadi TIDAK perlu di-set apa pun
# di VPS, tanggal & jam laporan tetap benar walau server default UTC.
#
# Set TZ di sini HANYA jika toko pindah zona waktu (mis. Jakarta = Asia/Jakarta
# WIB UTC+7, Papua = Asia/Jayapura WIT UTC+9). Bila di-set, nilai ini menang.
# TZ="Asia/Makassar"
