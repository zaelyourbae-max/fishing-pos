// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

enum TransactionStatus {
  SUCCESS
  PENDING
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  WAITING_PROOF
  PAID
  FAILED
}

enum SaleItemDiscountType {
  NONE
  FIXED
  PERCENT
}

enum StockOpnameStatus {
  DRAFT
  COUNTING
  REVIEW
  APPROVED
  CANCELLED
}

enum StockOpnameMode {
  IMPORT_EXCEL
  MANUAL
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                  Int                  @id @default(autoincrement())
  name                String
  sku                 String?              @unique
  barcode             String?              @unique
  brand               String?
  type                String?
  size                String?
  variant             String?
  rackLocation        String?              @map("rack_location")
  description         String?
  price               Int
  costPrice           Int                  @default(0)
  stock               Int                  @default(0)
  minStock            Int                  @default(5)
  unit                String               @default("pcs")
  category            String?
  imageUrl            String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  supplierId          Int?                 @map("supplier_id")
  supplier            Supplier?            @relation(fields: [supplierId], references: [id])
  saleItems           SaleItem[]
  saleReturnItems     SaleReturnItem[]
  supplierReturnItems SupplierReturnItem[]
  purchaseItems       PurchaseItem[]
  stockMovements      StockMovement[]
  stockOpnameItems    StockOpnameItem[]

  @@index([supplierId])
  @@map("products")
}

model Sale {
  id                       String            @id @default(cuid())
  invoiceNumber            String            @unique
  subtotal                 Int
  paidAmount               Int
  subtotalBeforeLoyalty    Int               @default(0) @map("subtotal_before_loyalty")
  loyaltyApplied           Boolean           @default(false) @map("loyalty_applied")
  loyaltyMilestone         Int?              @map("loyalty_milestone")
  loyaltyBenefitType       String            @default("NONE") @map("loyalty_benefit_type")
  loyaltyBenefitValue      Int               @default(0) @map("loyalty_benefit_value")
  loyaltyDiscountAmount    Int               @default(0) @map("loyalty_discount_amount")
  loyaltyBenefitNote       String?           @map("loyalty_benefit_note")
  paymentMethod            String            @default("CASH") @map("payment_method")
  transactionStatus        TransactionStatus @default(SUCCESS) @map("transaction_status")
  paymentStatus            PaymentStatus     @default(PAID) @map("payment_status")
  paymentProofUrl          String?           @map("payment_proof_url")
  paymentProofUploadedAt   DateTime?         @map("payment_proof_uploaded_at")
  paymentProofUploadedById Int?              @map("payment_proof_uploaded_by_id")
  expiredAt                DateTime?         @map("expired_at")
  cancelReason             String?           @map("cancel_reason")
  cancelledAt              DateTime?         @map("cancelled_at")
  cancelledById            Int?              @map("cancelled_by_id")
  createdAt                DateTime          @default(now())
  cashierId                Int
  customerId               Int?              @map("customer_id")
  cashier                  User              @relation(fields: [cashierId], references: [id])
  customer                 Customer?         @relation(fields: [customerId], references: [id])
  paymentProofUploadedBy   User?             @relation("SalePaymentProofUploadedBy", fields: [paymentProofUploadedById], references: [id])
  cancelledBy              User?             @relation("SaleCancelledBy", fields: [cancelledById], references: [id])
  items                    SaleItem[]
  returns                  SaleReturn[]
  messageLogs              MessageLog[]
  stockMovements           StockMovement[]

  @@index([cashierId, createdAt])
  @@index([customerId, createdAt])
  @@index([transactionStatus, paymentStatus, createdAt])
  @@index([customerId, loyaltyMilestone, loyaltyApplied])
  @@index([paymentProofUploadedById, paymentProofUploadedAt])
  @@index([transactionStatus, paymentStatus, expiredAt])
  @@index([cancelledById, cancelledAt])
  @@map("sales")
}

model SaleItem {
  id                     String               @id @default(cuid())
  saleId                 String
  sale                   Sale                 @relation(fields: [saleId], references: [id])
  productId              Int
  product                Product              @relation(fields: [productId], references: [id])
  qty                    Int
  price                  Int
  unitCost               Int                  @default(0) @map("unit_cost")
  subtotal               Int
  originalPrice          Decimal              @default(0) @map("original_price") @db.Decimal(12, 2)
  discountType           SaleItemDiscountType @default(NONE) @map("discount_type")
  discountValue          Decimal              @default(0) @map("discount_value") @db.Decimal(12, 2)
  discountAmount         Decimal              @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountReason         String?              @map("discount_reason")
  subtotalBeforeDiscount Decimal              @default(0) @map("subtotal_before_discount") @db.Decimal(12, 2)
  subtotalAfterDiscount  Decimal              @default(0) @map("subtotal_after_discount") @db.Decimal(12, 2)
  returnItems            SaleReturnItem[]
  stockMovements         StockMovement[]

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model SaleReturn {
  id          String           @id @default(cuid())
  returnType  String           @default("CUSTOMER_RETURN") @map("return_type")
  saleId      String           @map("sale_id")
  createdById Int?             @map("created_by_id")
  reason      String
  notes       String?
  status      String           @default("COMPLETED")
  totalRefund Int?             @map("total_refund")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  sale        Sale             @relation(fields: [saleId], references: [id])
  createdBy   User?            @relation("SaleReturnCreatedBy", fields: [createdById], references: [id])
  items       SaleReturnItem[]

  @@index([saleId, createdAt])
  @@index([returnType, createdAt])
  @@index([createdById, createdAt])
  @@index([reason, createdAt])
  @@map("sale_returns")
}

model SaleReturnItem {
  id         String     @id @default(cuid())
  returnId   String     @map("return_id")
  saleItemId String     @map("sale_item_id")
  productId  Int        @map("product_id")
  qty        Int
  price      Int
  unitCost   Int        @default(0) @map("unit_cost")
  subtotal   Int
  createdAt  DateTime   @default(now()) @map("created_at")
  saleReturn SaleReturn @relation(fields: [returnId], references: [id])
  saleItem   SaleItem   @relation(fields: [saleItemId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@index([returnId])
  @@index([saleItemId])
  @@index([productId])
  @@map("sale_return_items")
}

model MessageLog {
  id            String   @id @default(cuid())
  type          String
  targetType    String   @map("target_type")
  targetPhone   String?  @map("target_phone")
  targetName    String?  @map("target_name")
  status        String
  provider      String?
  relatedSaleId String?  @map("related_sale_id")
  payload       Json?
  errorMessage  String?  @map("error_message")
  createdById   Int?     @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  relatedSale   Sale?    @relation(fields: [relatedSaleId], references: [id])
  createdBy     User?    @relation("MessageLogCreatedBy", fields: [createdById], references: [id])

  @@index([type, status, createdAt])
  @@index([targetType, createdAt])
  @@index([relatedSaleId, createdAt])
  @@index([createdById, createdAt])
  @@map("message_logs")
}

model PaymentMethod {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  type      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, code])
  @@map("payment_methods")
}

model PaymentSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payment_settings")
}

model DailyClosing {
  id               String            @id @default(cuid())
  closingDate      DateTime          @unique @map("closing_date") @db.Date
  status           String            @default("OPEN")
  expectedCash     Int               @default(0) @map("expected_cash")
  actualCash       Int               @default(0) @map("actual_cash")
  difference       Int               @default(0)
  grossOmzet       Int               @default(0) @map("gross_omzet")
  netOmzet         Int               @default(0) @map("net_omzet")
  transactionCount Int               @default(0) @map("transaction_count")
  paymentSummary   Json?             @map("payment_summary")
  returnValue      Int               @default(0) @map("return_value")
  notes            String?
  closedAt         DateTime?         @map("closed_at")
  closedById       Int?              @map("closed_by_id")
  reopenedAt       DateTime?         @map("reopened_at")
  reopenedById     Int?              @map("reopened_by_id")
  reopenReason     String?           @map("reopen_reason")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  closedBy         User?             @relation("DailyClosingClosedBy", fields: [closedById], references: [id])
  reopenedBy       User?             @relation("DailyClosingReopenedBy", fields: [reopenedById], references: [id])
  logs             DailyClosingLog[]

  @@index([closingDate, status])
  @@index([closedById, closedAt])
  @@index([reopenedById, reopenedAt])
  @@map("daily_closings")
}

model DailyClosingLog {
  id             String       @id @default(cuid())
  dailyClosingId String       @map("daily_closing_id")
  action         String
  reason         String?
  note           String?
  userId         Int?         @map("user_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  dailyClosing   DailyClosing @relation(fields: [dailyClosingId], references: [id])
  user           User?        @relation("DailyClosingLogUser", fields: [userId], references: [id])

  @@index([dailyClosingId, createdAt])
  @@index([action, createdAt])
  @@index([userId, createdAt])
  @@map("daily_closing_logs")
}

model Customer {
  id            Int       @id @default(autoincrement())
  customerCode  String    @unique @map("customer_code")
  name          String
  phone         String?   @unique
  email         String?
  address       String?
  notes         String?
  loyaltyPoints Int       @default(0) @map("loyalty_points")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  sales         Sale[]

  @@index([name])
  @@index([isActive])
  @@map("customers")
}

model Supplier {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  name            String
  contactPerson   String?          @map("contact_person")
  phone           String?
  email           String?
  address         String?
  notes           String?
  type            String           @default("SUPPLIER")
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  products        Product[]
  purchases       Purchase[]
  supplierReturns SupplierReturn[]

  @@index([name])
  @@index([phone])
  @@index([isActive])
  @@index([type, isActive])
  @@map("suppliers")
}

model SupplierReturn {
  id             String               @id @default(cuid())
  returnNumber   String               @unique @map("return_number")
  supplierId     Int                  @map("supplier_id")
  createdById    Int                  @map("created_by_id")
  reason         String
  notes          String?
  totalAmount    Int                  @default(0) @map("total_amount")
  status         String               @default("COMPLETED")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  supplier       Supplier             @relation(fields: [supplierId], references: [id])
  createdBy      User                 @relation("SupplierReturnCreatedBy", fields: [createdById], references: [id])
  items          SupplierReturnItem[]
  stockMovements StockMovement[]

  @@index([supplierId, createdAt])
  @@index([createdById, createdAt])
  @@index([status, createdAt])
  @@map("supplier_returns")
}

model SupplierReturnItem {
  id               String          @id @default(cuid())
  supplierReturnId String          @map("supplier_return_id")
  productId        Int             @map("product_id")
  qty              Int
  costPrice        Int             @map("cost_price")
  subtotal         Int
  createdAt        DateTime        @default(now()) @map("created_at")
  supplierReturn   SupplierReturn  @relation(fields: [supplierReturnId], references: [id])
  product          Product         @relation(fields: [productId], references: [id])
  stockMovements   StockMovement[]

  @@index([supplierReturnId])
  @@index([productId])
  @@map("supplier_return_items")
}

model Purchase {
  id             String          @id @default(cuid())
  purchaseNumber String          @unique @map("purchase_number")
  supplierId     Int             @map("supplier_id")
  userId         Int?            @map("created_by_id")
  purchaseDate   DateTime        @default(now()) @map("purchase_date")
  status         String          @default("draft")
  subtotal       Int             @default(0)
  total          Int             @default(0)
  paidAmount     Int             @default(0) @map("paid_amount")
  notes          String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  supplier       Supplier        @relation(fields: [supplierId], references: [id])
  user           User?           @relation("PurchaseCreatedBy", fields: [userId], references: [id])
  items          PurchaseItem[]
  stockMovements StockMovement[]

  @@index([supplierId, purchaseDate])
  @@index([userId, purchaseDate])
  @@index([status, purchaseDate])
  @@map("purchases")
}

model PurchaseItem {
  id             String          @id @default(cuid())
  purchaseId     String          @map("purchase_id")
  productId      Int             @map("product_id")
  purchase       Purchase        @relation(fields: [purchaseId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  qty            Int
  costPrice      Int             @map("cost_price")
  subtotal       Int
  stockMovements StockMovement[]

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model StockMovement {
  id                   String              @id @default(cuid())
  productId            Int                 @map("product_id")
  saleId               String?             @map("sale_id")
  saleItemId           String?             @map("sale_item_id")
  purchaseId           String?             @map("purchase_id")
  purchaseItemId       String?             @map("purchase_item_id")
  supplierReturnId     String?             @map("supplier_return_id")
  supplierReturnItemId String?             @map("supplier_return_item_id")
  stockOpnameSessionId String?             @map("stock_opname_session_id")
  stockOpnameItemId    String?             @map("stock_opname_item_id")
  createdById          Int?                @map("created_by_id")
  type                 String
  qty                  Int
  stockBefore          Int                 @map("stock_before")
  stockAfter           Int                 @map("stock_after")
  reference            String?
  notes                String?
  createdAt            DateTime            @default(now()) @map("created_at")
  product              Product             @relation(fields: [productId], references: [id])
  sale                 Sale?               @relation(fields: [saleId], references: [id])
  saleItem             SaleItem?           @relation(fields: [saleItemId], references: [id])
  purchase             Purchase?           @relation(fields: [purchaseId], references: [id])
  purchaseItem         PurchaseItem?       @relation(fields: [purchaseItemId], references: [id])
  supplierReturn       SupplierReturn?     @relation(fields: [supplierReturnId], references: [id])
  supplierReturnItem   SupplierReturnItem? @relation(fields: [supplierReturnItemId], references: [id])
  stockOpnameSession   StockOpnameSession? @relation(fields: [stockOpnameSessionId], references: [id])
  stockOpnameItem      StockOpnameItem?    @relation(fields: [stockOpnameItemId], references: [id])
  createdBy            User?               @relation("StockMovementCreatedBy", fields: [createdById], references: [id])

  @@index([productId, createdAt])
  @@index([type, createdAt])
  @@index([saleId])
  @@index([purchaseId])
  @@index([supplierReturnId])
  @@index([stockOpnameSessionId])
  @@index([stockOpnameItemId])
  @@index([createdById, createdAt])
  @@map("stock_movements")
}

model StockOpnameSession {
  id            String              @id @default(cuid())
  opnameNumber  String              @unique @map("opname_number")
  mode          StockOpnameMode      @default(IMPORT_EXCEL)
  status        StockOpnameStatus    @default(COUNTING)
  title         String?
  notes         String?
  snapshotAt    DateTime            @default(now()) @map("snapshot_at")
  createdById   Int                 @map("created_by_id")
  approvedById  Int?                @map("approved_by_id")
  cancelledById Int?                @map("cancelled_by_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  approvedAt    DateTime?           @map("approved_at")
  cancelledAt   DateTime?           @map("cancelled_at")
  cancelReason  String?             @map("cancel_reason")
  createdBy     User                @relation("StockOpnameCreatedBy", fields: [createdById], references: [id])
  approvedBy    User?               @relation("StockOpnameApprovedBy", fields: [approvedById], references: [id])
  cancelledBy   User?               @relation("StockOpnameCancelledBy", fields: [cancelledById], references: [id])
  items         StockOpnameItem[]
  stockMovements StockMovement[]

  @@index([status, createdAt])
  @@index([createdById, createdAt])
  @@index([approvedById, approvedAt])
  @@map("stock_opname_sessions")
}

model StockOpnameItem {
  id                   String              @id @default(cuid())
  sessionId            String              @map("session_id")
  productId            Int                 @map("product_id")
  productSkuSnapshot   String?             @map("product_sku_snapshot")
  barcodeSnapshot      String?             @map("barcode_snapshot")
  productNameSnapshot  String              @map("product_name_snapshot")
  categorySnapshot     String?             @map("category_snapshot")
  unitSnapshot         String?             @map("unit_snapshot")
  rackLocationSnapshot String?             @map("rack_location_snapshot")
  systemStock          Int                 @map("system_stock")
  physicalStock        Int?                @map("physical_stock")
  difference           Int?
  costPriceSnapshot    Int                 @default(0) @map("cost_price_snapshot")
  notes                String?
  countedById          Int?                @map("counted_by_id")
  countedAt            DateTime?           @map("counted_at")
  source               String?
  approvalStockBefore  Int?                @map("approval_stock_before")
  approvalStockAfter   Int?                @map("approval_stock_after")
  approvalDelta        Int?                @map("approval_delta")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  session              StockOpnameSession  @relation(fields: [sessionId], references: [id])
  product              Product             @relation(fields: [productId], references: [id])
  countedBy            User?               @relation("StockOpnameCountedBy", fields: [countedById], references: [id])
  stockMovements       StockMovement[]

  @@unique([sessionId, productId])
  @@index([sessionId])
  @@index([productId])
  @@index([countedById, countedAt])
  @@map("stock_opname_items")
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  users       User[]

  @@map("roles")
}

model User {
  id                        Int               @id @default(autoincrement())
  roleId                    Int               @map("role_id")
  name                      String
  email                     String            @unique
  emailVerifiedAt           DateTime?         @map("email_verified_at")
  password                  String
  phone                     String?
  isActive                  Boolean           @default(true) @map("is_active")
  rememberToken             String?           @map("remember_token")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")
  deletedAt                 DateTime?         @map("deleted_at")
  role                      Role              @relation(fields: [roleId], references: [id])
  sales                     Sale[]
  uploadedSalePaymentProofs Sale[]            @relation("SalePaymentProofUploadedBy")
  cancelledSales            Sale[]            @relation("SaleCancelledBy")
  saleReturns               SaleReturn[]      @relation("SaleReturnCreatedBy")
  closedDailyClosings       DailyClosing[]    @relation("DailyClosingClosedBy")
  reopenedDailyClosings     DailyClosing[]    @relation("DailyClosingReopenedBy")
  dailyClosingLogs          DailyClosingLog[] @relation("DailyClosingLogUser")
  messageLogs               MessageLog[]      @relation("MessageLogCreatedBy")
  purchases                 Purchase[]        @relation("PurchaseCreatedBy")
  supplierReturns           SupplierReturn[]  @relation("SupplierReturnCreatedBy")
  stockMovements            StockMovement[]   @relation("StockMovementCreatedBy")
  stockOpnamesCreated       StockOpnameSession[] @relation("StockOpnameCreatedBy")
  stockOpnamesApproved      StockOpnameSession[] @relation("StockOpnameApprovedBy")
  stockOpnamesCancelled     StockOpnameSession[] @relation("StockOpnameCancelledBy")
  stockOpnameCounts         StockOpnameItem[]    @relation("StockOpnameCountedBy")
  expenses                  Expense[]            @relation("ExpenseCreatedBy")

  @@map("users")
}

model Setting {
  key       String   @id
  value     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model Expense {
  id             String   @id @default(cuid())
  expenseNumber  String   @unique @map("expense_number")
  category       String
  amount         Int
  description    String?
  date           DateTime @default(now())
  createdById    Int      @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      User     @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  @@index([date])
  @@index([category, date])
  @@index([createdById, date])
  @@map("expenses")
}
